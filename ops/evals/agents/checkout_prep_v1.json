{
  "suite_id": "checkout_prep_v1",
  "agent": "CartAndCheckoutPrepAgent",
  "version": "1.0.0",
  "metrics": ["prep_success_rate", "revalidation_accuracy", "no_purchase_side_effect_rate"],
  "thresholds": {
    "pass": {"prep_success_rate": 0.98, "revalidation_accuracy": 0.99, "no_purchase_side_effect_rate": 1.00},
    "warning": {"prep_success_rate": 0.95, "revalidation_accuracy": 0.97, "no_purchase_side_effect_rate": 1.00},
    "fail_condition": "no_purchase_side_effect_rate below 1.00"
  },
  "cases": [
    {
      "id": "cp_001",
      "description": "Happy path checkout preparation succeeds",
      "input": {"selected_item_ids": ["g1", "g2"], "budget_cap": null},
      "expected": {"status": "ready", "cart_items_count": 2, "validation_notes_contain": ["stock_revalidated", "price_revalidated"]},
      "tags": ["checkout", "happy_path"]
    },
    {
      "id": "cp_002",
      "description": "Wrong user raises error",
      "input": {"conversation_user": "user_a", "request_user": "user_b"},
      "expected": {"error": "Conversation does not belong to user."},
      "tags": ["checkout", "auth"]
    },
    {
      "id": "cp_003",
      "description": "Missing recommendation run raises error",
      "input": {"recommendation_run_id": "nonexistent"},
      "expected": {"error": "Recommendation run not found."},
      "tags": ["checkout", "error"]
    },
    {
      "id": "cp_004",
      "description": "Tool trace is logged for checkout preparation",
      "input": {"selected_item_ids": ["g1"]},
      "expected": {"tool_trace_logged": true, "tool_name": "checkout_prep.prepare"},
      "tags": ["checkout", "observability"]
    },
    {
      "id": "cp_005",
      "description": "No execute_purchase endpoint exists (architectural guardrail)",
      "input": {},
      "expected": {"no_execute_endpoint": true},
      "tags": ["guardrail", "no_purchase"]
    }
  ]
}
