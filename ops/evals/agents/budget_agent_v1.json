{
  "suite_id": "budget_agent_v1",
  "agent": "BudgetAndDealAgent",
  "version": "1.0.0",
  "metrics": ["budget_compliance", "discount_correctness", "substitution_acceptability"],
  "thresholds": {
    "pass": {"budget_compliance": 0.98, "discount_correctness": 0.99, "substitution_acceptability": 0.80},
    "warning": {"budget_compliance": 0.95, "discount_correctness": 0.97, "substitution_acceptability": 0.72},
    "fail_condition": "budget compliance below warning"
  },
  "cases": [
    {
      "id": "ba_001",
      "description": "Within budget returns ready status",
      "input": {"items": [{"garment_id": "g1", "score": 2000}], "budget_cap": 5000},
      "expected": {"status": "ready", "substitution_count": 0},
      "tags": ["budget", "happy_path"]
    },
    {
      "id": "ba_002",
      "description": "Over budget with cheaper alternative suggests substitution",
      "input": {
        "selected": [{"garment_id": "g1", "score": 4000}],
        "available": [{"garment_id": "g2", "score": 1000}],
        "budget_cap": 3000
      },
      "expected": {"status": "needs_user_action", "has_substitution": true},
      "tags": ["budget", "substitution"]
    },
    {
      "id": "ba_003",
      "description": "Over budget with no alternative returns needs_user_action",
      "input": {"items": [{"garment_id": "g1", "score": 5000}], "budget_cap": 3000, "no_alternatives": true},
      "expected": {"status": "needs_user_action", "has_substitution": false},
      "tags": ["budget", "no_substitution"]
    },
    {
      "id": "ba_004",
      "description": "No budget cap always returns ready",
      "input": {"items": [{"garment_id": "g1", "score": 99999}], "budget_cap": null},
      "expected": {"status": "ready"},
      "tags": ["budget", "no_cap"]
    }
  ]
}
