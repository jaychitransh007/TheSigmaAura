{
  "suite_id": "policy_agent_v1",
  "agent": "PolicyGuardrailAgent",
  "version": "1.0.0",
  "metrics": ["unsafe_block_rate", "false_block_rate", "explanation_presence"],
  "thresholds": {
    "pass": {"unsafe_block_rate": 1.00, "false_block_rate": 0.03, "explanation_presence": 0.99},
    "warning": {"unsafe_block_rate": 0.99, "false_block_rate": 0.05, "explanation_presence": 0.97},
    "fail_condition": "unsafe block below warning"
  },
  "cases": [
    {
      "id": "pg_001",
      "description": "execute_purchase is blocked with explanation",
      "input": {"action": "execute_purchase"},
      "expected": {"allowed": false, "has_reason": true, "reason_mentions": "checkout"},
      "tags": ["block", "purchase"]
    },
    {
      "id": "pg_002",
      "description": "place_order is blocked",
      "input": {"action": "place_order"},
      "expected": {"allowed": false},
      "tags": ["block", "order"]
    },
    {
      "id": "pg_003",
      "description": "confirm_order is blocked",
      "input": {"action": "confirm_order"},
      "expected": {"allowed": false},
      "tags": ["block", "order"]
    },
    {
      "id": "pg_004",
      "description": "submit_order is blocked",
      "input": {"action": "submit_order"},
      "expected": {"allowed": false},
      "tags": ["block", "order"]
    },
    {
      "id": "pg_005",
      "description": "recommend action is allowed",
      "input": {"action": "recommend"},
      "expected": {"allowed": true},
      "tags": ["allow"]
    },
    {
      "id": "pg_006",
      "description": "prepare_checkout action is allowed",
      "input": {"action": "prepare_checkout"},
      "expected": {"allowed": true},
      "tags": ["allow"]
    },
    {
      "id": "pg_007",
      "description": "Case-insensitive blocking works",
      "input": {"action": "Execute_Purchase"},
      "expected": {"allowed": false},
      "tags": ["block", "normalization"]
    },
    {
      "id": "pg_008",
      "description": "Hyphenated variant is blocked",
      "input": {"action": "execute-purchase"},
      "expected": {"allowed": false},
      "tags": ["block", "normalization"]
    }
  ]
}
