{
  "suite_id": "intent_mode_router_v1",
  "agent": "IntentModeRouterAgent",
  "version": "1.0.0",
  "metrics": ["mode_accuracy", "garment_precision", "garment_recall"],
  "thresholds": {
    "pass": {"mode_accuracy": 0.95, "garment_precision": 0.97, "garment_recall": 0.90},
    "warning": {"mode_accuracy": 0.92, "garment_precision": 0.94, "garment_recall": 0.85},
    "fail_condition": "any metric below warning"
  },
  "cases": [
    {
      "id": "imr_001",
      "description": "Explicit garment keyword resolves to garment mode",
      "input": {"mode_preference": "auto", "target_garment_type": "shirt", "request_text": "Show me white shirts for office"},
      "expected": {"resolved_mode": "garment", "complete_the_look_offer": true, "requested_categories_any": ["top"]},
      "tags": ["garment_mode", "work_mode"]
    },
    {
      "id": "imr_002",
      "description": "Broad intent without garment keyword resolves to outfit mode",
      "input": {"mode_preference": "auto", "target_garment_type": null, "request_text": "I need a polished office look"},
      "expected": {"resolved_mode": "outfit", "complete_the_look_offer": false},
      "tags": ["outfit_mode", "work_mode"]
    },
    {
      "id": "imr_003",
      "description": "Explicit garment mode preference overrides auto",
      "input": {"mode_preference": "garment", "target_garment_type": null, "request_text": "anything"},
      "expected": {"resolved_mode": "garment", "complete_the_look_offer": true},
      "tags": ["garment_mode", "explicit"]
    },
    {
      "id": "imr_004",
      "description": "Explicit outfit mode preference overrides auto",
      "input": {"mode_preference": "outfit", "target_garment_type": null, "request_text": "anything"},
      "expected": {"resolved_mode": "outfit", "complete_the_look_offer": false},
      "tags": ["outfit_mode", "explicit"]
    },
    {
      "id": "imr_005",
      "description": "Kurta keyword triggers garment detection in auto mode",
      "input": {"mode_preference": "auto", "target_garment_type": null, "request_text": "Show me kurtas for festive season"},
      "expected": {"resolved_mode_any": ["garment", "outfit"]},
      "tags": ["auto_mode", "festive"]
    },
    {
      "id": "imr_006",
      "description": "Result always contains all required keys",
      "input": {"mode_preference": "auto", "target_garment_type": null, "request_text": "hello"},
      "expected": {"required_keys": ["resolved_mode", "complete_the_look_offer", "requested_categories", "requested_subtypes"]},
      "tags": ["contract"]
    },
    {
      "id": "imr_007",
      "description": "Pants keyword with auto mode resolves garment",
      "input": {"mode_preference": "auto", "target_garment_type": "pants", "request_text": "Show me formal trousers"},
      "expected": {"resolved_mode": "garment", "complete_the_look_offer": true},
      "tags": ["garment_mode", "formal"]
    },
    {
      "id": "imr_008",
      "description": "Date night broad request resolves outfit",
      "input": {"mode_preference": "auto", "target_garment_type": null, "request_text": "Help me dress for a date tonight"},
      "expected": {"resolved_mode": "outfit", "complete_the_look_offer": false},
      "tags": ["outfit_mode", "date_night"]
    }
  ]
}
