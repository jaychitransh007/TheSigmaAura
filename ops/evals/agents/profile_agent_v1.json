{
  "suite_id": "profile_agent_v1",
  "agent": "UserProfileAgent",
  "version": "1.0.0",
  "metrics": ["schema_valid_rate", "merge_correctness", "size_completeness"],
  "thresholds": {
    "pass": {"schema_valid_rate": 1.00, "merge_correctness": 0.99, "size_completeness": 0.97},
    "warning": {"schema_valid_rate": 0.995, "merge_correctness": 0.97, "size_completeness": 0.94},
    "fail_condition": "schema_valid_rate < 1.00"
  },
  "cases": [
    {
      "id": "pa_001",
      "description": "Merge with empty existing profile creates valid profile",
      "input": {"existing": null, "initial_profile": {"sizes": {"top_size": "M"}}},
      "expected": {"sizes.top_size": "M"},
      "tags": ["merge", "empty_existing"]
    },
    {
      "id": "pa_002",
      "description": "Size overrides win over existing sizes",
      "input": {"existing": {"sizes": {"top_size": "S"}}, "size_overrides": {"top_size": "M", "bottom_size": "30"}},
      "expected": {"sizes.top_size": "M", "sizes.bottom_size": "30"},
      "tags": ["merge", "size_override"]
    },
    {
      "id": "pa_003",
      "description": "Last-write-wins for initial_profile keys",
      "input": {"existing": {"brand_preferences": {"liked": ["A"]}}, "initial_profile": {"brand_preferences": {"liked": ["B"]}}},
      "expected": {"brand_preferences.liked": ["B"]},
      "tags": ["merge", "last_write_wins"]
    },
    {
      "id": "pa_004",
      "description": "Existing fields preserved when initial_profile adds new keys",
      "input": {"existing": {"consent_flags": {"image_inference_allowed": true}}, "initial_profile": {"sizes": {"top_size": "L"}}},
      "expected": {"consent_flags.image_inference_allowed": true, "sizes.top_size": "L"},
      "tags": ["merge", "preserve_existing"]
    },
    {
      "id": "pa_005",
      "description": "profile_fields_used excludes color_preferences",
      "input": {"profile": {"HeightCategory": "average", "color_preferences": {"loved": ["red"]}}},
      "expected": {"fields_used_contains": ["HeightCategory"], "fields_used_excludes": ["color_preferences"]},
      "tags": ["fields_used"]
    },
    {
      "id": "pa_006",
      "description": "Empty profile returns empty fields list",
      "input": {"profile": {}},
      "expected": {"fields_used": []},
      "tags": ["fields_used", "edge_case"]
    }
  ]
}
